#!/bin/sh
# ccthread dispatcher — downloads the right binary on first run, then execs.
# Pinned version in .ccthread-version (kept in lockstep with plugin.json).
set -e

ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"
DATA="${CLAUDE_PLUGIN_DATA:-$HOME/.claude/plugins/data/ccthread}"
VERSION=$(cat "$ROOT/bin/.ccthread-version" | tr -d '[:space:]')

# Detect target triple.
OS=$(uname -s)
ARCH=$(uname -m)
case "$OS-$ARCH" in
  Darwin-arm64)  TARGET="bun-darwin-arm64";           EXE="ccthread" ;;
  Darwin-x86_64) TARGET="bun-darwin-x64-baseline";    EXE="ccthread" ;;
  Linux-x86_64)  TARGET="bun-linux-x64-baseline";     EXE="ccthread" ;;
  Linux-aarch64|Linux-arm64) TARGET="bun-linux-arm64"; EXE="ccthread" ;;
  *)
    echo "ccthread: unsupported platform $OS/$ARCH" >&2
    echo "Install manually: https://github.com/jakemarsh/ccthread/releases" >&2
    exit 1
  ;;
esac

BIN="$DATA/bin/ccthread-$VERSION-$TARGET/$EXE"

if [ ! -x "$BIN" ]; then
  mkdir -p "$(dirname "$BIN")"
  BASE="https://github.com/jakemarsh/ccthread/releases/download/v$VERSION"
  URL="$BASE/ccthread-v$VERSION-$TARGET.tar.gz"
  TMP=$(mktemp -d)
  trap 'rm -rf "$TMP"' EXIT
  if ! curl -fSL "$URL" -o "$TMP/ccthread.tar.gz" 2>/dev/null; then
    echo "ccthread: could not download $URL" >&2
    echo "Install manually: https://github.com/jakemarsh/ccthread/releases" >&2
    exit 1
  fi
  # Verify SHA256 if a sibling .sha256 exists at the release.
  if curl -fSL "$URL.sha256" -o "$TMP/ccthread.sha256" 2>/dev/null; then
    EXPECTED=$(awk '{print $1}' "$TMP/ccthread.sha256")
    if command -v shasum >/dev/null 2>&1; then
      ACTUAL=$(shasum -a 256 "$TMP/ccthread.tar.gz" | awk '{print $1}')
    else
      ACTUAL=$(sha256sum "$TMP/ccthread.tar.gz" | awk '{print $1}')
    fi
    if [ "$EXPECTED" != "$ACTUAL" ]; then
      echo "ccthread: SHA256 mismatch for $URL" >&2
      echo "  expected: $EXPECTED" >&2
      echo "  got:      $ACTUAL" >&2
      exit 1
    fi
  fi
  tar -xzf "$TMP/ccthread.tar.gz" -C "$TMP"
  FOUND=$(find "$TMP" -type f -name "$EXE" -perm -u+x 2>/dev/null | head -n1)
  if [ -z "$FOUND" ]; then
    echo "ccthread: couldn't find $EXE in the downloaded archive" >&2
    exit 1
  fi
  mv "$FOUND" "$BIN"
  chmod +x "$BIN"
fi

exec "$BIN" "$@"
