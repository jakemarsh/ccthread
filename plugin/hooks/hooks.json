{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/record-session.sh\""
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -File \"${CLAUDE_PLUGIN_ROOT}/hooks/record-session.ps1\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/cleanup-session.sh\""
          },
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -File \"${CLAUDE_PLUGIN_ROOT}/hooks/cleanup-session.ps1\""
          }
        ]
      }
    ]
  }
}
