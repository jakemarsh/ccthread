{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/record-session.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/cleanup-session.sh\""
          }
        ]
      }
    ]
  }
}
